{
  "name": "ai-web-framework",
  "version": "2.1.0",
  "description": "AI-Friendly Web Framework untuk development yang cepat dan mudah dimodifikasi oleh AI",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "dev:portal": "vite",
    "start": "node server.js",
    "build": "node scripts/build.js",
    "build:portal": "tsc && vite build",
    "deploy": "firebase deploy",
    "lint": "node scripts/lint.js",
    "typecheck": "node scripts/typecheck.js",
    "check": "npm run lint && npm run typecheck",
    "generate": "node scripts/generate.js",
    "docs": "node scripts/generate-docs.js",
    "ai:analyze": "node scripts/ai-analyze.js",
    "benchmark": "node scripts/benchmark.js",
    "cleanup": "node scripts/cleanup.js"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "ajv": "^8.12.0",
    "cannon-es": "^0.20.0",
    "chokidar": "^3.5.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.10.0",
    "helmet": "^8.1.0",
    "highlight.js": "^11.9.0",
    "javascript-obfuscator": "^5.3.0",
    "jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^9.1.2",
    "morgan": "^1.10.1",
    "msgpack5": "^6.0.2",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1",
    "winston": "^3.19.0",
    "ws": "^8.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "nodemon": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "keywords": [
    "ai",
    "framework",
    "web",
    "generator",
    "automation",
    "ai-friendly",
    "intelligent"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "aiFramework": {
    "version": "2.1.0",
    "features": [
      "intelligent-templates",
      "context-learning",
      "pattern-recognition",
      "auto-documentation",
      "validation-schemas",
      "hot-reload",
      "version-control",
      "performance-monitoring",
      "error-handling",
      "batch-operations",
      "caching",
      "rate-limiting",
      "metrics-collection",
      "request-validation",
      "security-hardening"
    ]
  }
}
