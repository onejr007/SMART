{
  "name": "smart-metaverse-portal",
  "version": "2.0.0",
  "description": "Standalone Firebase Game Portal & Multiverse Engine for web-based 3D games",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite preview",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "dompurify": "^3.3.3",
    "firebase": "^12.10.0",
    "highlight.js": "^11.9.0",
    "marked": "^9.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "game",
    "metaverse",
    "multiverse",
    "engine",
    "portal",
    "threejs",
    "ugc",
    "firebase",
    "standalone",
    "react",
    "vite"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "aiFramework": {
    "version": "2.1.0",
    "features": [
      "intelligent-templates",
      "context-learning",
      "pattern-recognition",
      "auto-documentation",
      "validation-schemas",
      "hot-reload",
      "version-control",
      "performance-monitoring",
      "error-handling",
      "batch-operations",
      "caching",
      "rate-limiting",
      "metrics-collection",
      "request-validation",
      "security-hardening"
    ]
  }
}
