# Server Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL=30000
MAX_CACHE_ENTRIES=200

# Security
ALLOWED_ORIGINS=http://localhost:5173
HELMET_ENABLED=true
JWT_SECRET=your_super_secret_key_here
GRPC_AUTH_ENABLED=true

# Firebase Realtime Database (server-side only)
FIREBASE_DB_URL=https://<your-db>.firebasedatabase.app
FIREBASE_AUTH_SECRET=your_firebase_database_secret

# Firebase Hosting & Analytics (client-side)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Performance
MAX_REQUEST_SIZE=10mb
COMPRESSION_ENABLED=true

# AI Configuration
MAX_COMPONENT_NAME_LENGTH=50
MAX_CONTENT_LENGTH=50000
MAX_BATCH_SIZE=50
