{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid",
        "role": {
          ".validate": "newData.val() == 'admin' || newData.val() == 'creator' || newData.val() == 'player'"
        }
      }
    },
    "games": {
      ".read": true,
      "$gameId": {
        ".write": "auth != null && (!data.exists() || data.child('authorId').val() == auth.uid)",
        ".validate": "newData.hasChildren(['title', 'authorId', 'createdAt', 'scene'])",
        "title": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "authorId": {
          ".validate": "newData.val() === auth.uid"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "scene": {
          ".validate": "newData.isString() ? newData.val().length <= 5000000 : true"
        }
      }
    },
    "user_game_data": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "leaderboards": {
      ".read": true,
      "$gameId": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid",
          ".validate": "newData.hasChildren(['score', 'timestamp'])",
          "score": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "timestamp": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },
    "audit_logs": {
      ".read": "root.child('users').child(auth.uid).child('role').val() == 'admin'",
      ".write": "auth != null"
    }
  }
}
