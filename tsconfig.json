{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "src/engine/NetworkBootstrap.ts",
    "src/engine/SocialBootstrap.ts",
    "src/engine/SecurityBootstrap.ts",
    "src/engine/RenderingBootstrap.ts",
    "src/engine/ContentBootstrap.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
